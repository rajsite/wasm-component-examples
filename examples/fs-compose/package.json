{
  "name": "fs-compose",
  "version": "1.0.0",
  "private": "true",
  "type": "module",
  "scripts": {
    "build-wit": "echo \"skip build wasm\"",
    "build-wasm": "mkdirp dist && wac plug ../fs-export/dist/main.wasm --plug ../fs-read/dist/main.wasm -o dist/main.wasm",
    "build": "npm run build-wit && npm run build-wasm",
    "start-wasmtime": "wasmtime run -S cli=y,http=y --dir . dist/main.wasm",
    "pack": "npm pack",
    "clean": "git clean -fdx -e '.env.*'"
  },
  "dependencies": {
    "fs-export": "*",
    "fs-read": "*"
  },
  "devDependencies": {
    "mkdirp": "^3.0.1"
  }
}
